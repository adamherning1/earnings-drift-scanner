// This Pine Script™ v5 strategy is for Micro Gold Futures (MGC1!)
// Strategy: London Open Breakout
// Timeframe: 5-min or 15-min recommended
//@version=5
strategy("London Open Breakout - MGC", overlay=true, initial_capital=10000,
     default_qty_type=strategy.fixed, default_qty_value=1,
     commission_type=strategy.commission.cash_per_contract, commission_value=1.25,
     slippage=1, currency=currency.USD, calc_on_every_tick=false,
     process_orders_on_close=false)

// ──────────────────────────────────────────────────────────────────────────────
// INPUTS
// ──────────────────────────────────────────────────────────────────────────────
grpSession  = "Session Settings"
asianStart  = input.int(18, "Asian Session Start Hour (ET)", minval=0, maxval=23, group=grpSession, tooltip="Default 6PM ET")
asianEnd    = input.int(2,  "Asian Session End Hour (ET)",   minval=0, maxval=23, group=grpSession, tooltip="Default 2AM ET")
londonHour  = input.int(3,  "London Open Hour (ET)",         minval=0, maxval=23, group=grpSession, tooltip="Default 3AM ET")
nyCloseHour = input.int(17, "NY Session Close Hour (ET)",    minval=0, maxval=23, group=grpSession, tooltip="Default 5PM ET — all positions closed")

grpTrade    = "Trade Settings"
rrRatio     = input.float(1.5, "Reward:Risk Ratio", minval=0.5, step=0.1, group=grpTrade)
maxRange    = input.float(15.0, "Max Asian Range (points)", minval=1.0, step=0.5, group=grpTrade, tooltip="Skip day if range exceeds this")
useATRStop  = input.bool(false, "Use ATR-Based Stop Instead of Range", group=grpTrade)
atrLength   = input.int(14, "ATR Length (if ATR stop)", minval=1, group=grpTrade)
atrMult     = input.float(1.5, "ATR Multiplier (if ATR stop)", minval=0.5, step=0.1, group=grpTrade)
offsetPts   = input.float(0.5, "Entry Offset Above/Below Range (points)", minval=0.0, step=0.1, group=grpTrade)

grpVisual   = "Visuals"
showBox     = input.bool(true, "Show Asian Range Box", group=grpVisual)
boxColor    = input.color(color.new(color.blue, 80), "Box Color", group=grpVisual)

// ──────────────────────────────────────────────────────────────────────────────
// TIME HELPERS — convert exchange time to ET
// We use the "America/New_York" timezone for all session logic.
// ──────────────────────────────────────────────────────────────────────────────
etHour  = hour(time, "America/New_York")
etMin   = minute(time, "America/New_York")
etDay   = dayofweek(time, "America/New_York")

// Asian session spans across midnight so we handle wrap-around
isAsianSession = asianStart > asianEnd
     ? (etHour >= asianStart or etHour < asianEnd)
     : (etHour >= asianStart and etHour < asianEnd)

isLondonOpen   = (etHour == londonHour and etMin == 0)
isNYClose      = (etHour == nyCloseHour and etMin == 0)

// ──────────────────────────────────────────────────────────────────────────────
// ASIAN RANGE TRACKING
// ──────────────────────────────────────────────────────────────────────────────
var float asianHigh    = na
var float asianLow     = na
var bool  rangeReady   = false
var bool  tradedToday  = false
var int   boxLeft      = na

// Reset at start of Asian session
if isAsianSession and not isAsianSession[1]
    asianHigh   := high
    asianLow    := low
    rangeReady  := false
    tradedToday := false
    boxLeft     := bar_index

// Track range during Asian session
if isAsianSession
    asianHigh := math.max(nz(asianHigh, high), high)
    asianLow  := math.min(nz(asianLow, low), low)

// Lock range at end of Asian session
if not isAsianSession and isAsianSession[1]
    rangeReady := true

// ──────────────────────────────────────────────────────────────────────────────
// VISUAL: ASIAN RANGE BOX
// ──────────────────────────────────────────────────────────────────────────────
var box asianBox = na
if showBox and not isAsianSession and isAsianSession[1] and not na(asianHigh) and not na(asianLow)
    asianBox := box.new(left=boxLeft, top=asianHigh, right=bar_index, bottom=asianLow,
         border_color=color.blue, bgcolor=boxColor, border_width=1)

// Extend box right edge while in London/NY
if showBox and not na(asianBox) and rangeReady
    box.set_right(asianBox, bar_index)

// Plot levels
plot(rangeReady ? asianHigh : na, "Asian High", color=color.new(color.green, 40), style=plot.style_linebr, linewidth=1)
plot(rangeReady ? asianLow  : na, "Asian Low",  color=color.new(color.red, 40),   style=plot.style_linebr, linewidth=1)

// ──────────────────────────────────────────────────────────────────────────────
// ATR (for optional ATR-based stops)
// ──────────────────────────────────────────────────────────────────────────────
atrVal = ta.atr(atrLength)

// ──────────────────────────────────────────────────────────────────────────────
// ENTRY LOGIC — at London open bar
// ──────────────────────────────────────────────────────────────────────────────
rangeSize = asianHigh - asianLow
rangeOK   = rangeSize > 0 and rangeSize <= maxRange

if isLondonOpen and rangeReady and rangeOK and not tradedToday
    // Calculate stops and targets
    float longEntry  = asianHigh + offsetPts
    float shortEntry = asianLow  - offsetPts
    float longStop   = useATRStop ? longEntry  - atrMult * atrVal : asianLow
    float shortStop  = useATRStop ? shortEntry + atrMult * atrVal : asianHigh
    float longRisk   = longEntry - longStop
    float shortRisk  = shortStop - shortEntry
    float longTP     = longEntry  + rrRatio * longRisk
    float shortTP    = shortEntry - rrRatio * shortRisk

    // Place buy stop order above Asian high
    strategy.entry("Long",  strategy.long,  stop=longEntry)
    strategy.exit("Long TP/SL", "Long", limit=longTP, stop=longStop)

    // Place sell stop order below Asian low
    strategy.entry("Short", strategy.short, stop=shortEntry)
    strategy.exit("Short TP/SL", "Short", limit=shortTP, stop=shortStop)

    tradedToday := true

// ──────────────────────────────────────────────────────────────────────────────
// CANCEL UNFILLED ORDERS & CLOSE AT NY SESSION END
// ──────────────────────────────────────────────────────────────────────────────
// Cancel pending orders if neither triggered by a cutoff (e.g., noon ET)
if etHour >= 12 and tradedToday
    // Cancel any unfilled stop orders
    if strategy.position_size == 0
        strategy.cancel("Long")
        strategy.cancel("Short")

// Close all positions at NY close
if isNYClose
    strategy.close_all(comment="NY Close")
    strategy.cancel_all()
    rangeReady := false

// ──────────────────────────────────────────────────────────────────────────────
// CANCEL OPPOSITE SIDE once one side fills
// ──────────────────────────────────────────────────────────────────────────────
if strategy.position_size > 0
    strategy.cancel("Short")
if strategy.position_size < 0
    strategy.cancel("Long")

// ──────────────────────────────────────────────────────────────────────────────
// ALERT CONDITIONS
// ──────────────────────────────────────────────────────────────────────────────
alertcondition(isLondonOpen and rangeReady and rangeOK and not tradedToday,
     title="London Breakout Setup", message="MGC London Breakout: Asian Range {{asianLow}}-{{asianHigh}}")

// ──────────────────────────────────────────────────────────────────────────────
// INFO TABLE
// ──────────────────────────────────────────────────────────────────────────────
var table infoTbl = table.new(position.top_right, 2, 4, bgcolor=color.new(color.gray, 85))
if barstate.islast
    table.cell(infoTbl, 0, 0, "Asian High",  text_color=color.white)
    table.cell(infoTbl, 1, 0, str.tostring(asianHigh, format.mintick), text_color=color.green)
    table.cell(infoTbl, 0, 1, "Asian Low",   text_color=color.white)
    table.cell(infoTbl, 1, 1, str.tostring(asianLow, format.mintick),  text_color=color.red)
    table.cell(infoTbl, 0, 2, "Range",       text_color=color.white)
    table.cell(infoTbl, 1, 2, str.tostring(rangeSize, "#.##"),         text_color=rangeOK ? color.green : color.red)
    table.cell(infoTbl, 0, 3, "Status",      text_color=color.white)
    table.cell(infoTbl, 1, 3, tradedToday ? "Traded" : rangeReady ? "Ready" : "Building", text_color=color.yellow)
