// This Pine Script™ v5 strategy is for Micro Gold Futures (MGC1!)
// Strategy: RSI(2) Mean Reversion during Asian Session
// Timeframe: 5-minute recommended
//@version=5
strategy("RSI(2) Mean Reversion - MGC", overlay=true, initial_capital=10000,
     default_qty_type=strategy.fixed, default_qty_value=1,
     commission_type=strategy.commission.cash_per_contract, commission_value=1.25,
     slippage=1, currency=currency.USD, calc_on_every_tick=false)

// ──────────────────────────────────────────────────────────────────────────────
// INPUTS
// ──────────────────────────────────────────────────────────────────────────────
grpRSI     = "RSI Settings"
rsiLen     = input.int(2, "RSI Length", minval=1, group=grpRSI)
oversold   = input.float(10.0, "Oversold Level (Buy)", minval=1.0, maxval=50.0, step=1.0, group=grpRSI)
overbought = input.float(90.0, "Overbought Level (Sell)", minval=50.0, maxval=99.0, step=1.0, group=grpRSI)
exitLevel  = input.float(50.0, "RSI Exit Level", minval=20.0, maxval=80.0, step=5.0, group=grpRSI)

grpSession = "Session Filter (ET)"
sessStart  = input.int(18, "Session Start Hour (ET)", minval=0, maxval=23, group=grpSession, tooltip="Default 6PM ET — Asian session start")
sessEnd    = input.int(2,  "Session End Hour (ET)",   minval=0, maxval=23, group=grpSession, tooltip="Default 2AM ET — Asian session end")
useSession = input.bool(true, "Only Trade During Session", group=grpSession)

grpRisk    = "Risk Management"
atrLen     = input.int(14, "ATR Length", minval=1, group=grpRisk)
atrMult    = input.float(1.0, "ATR Stop Multiplier", minval=0.5, step=0.1, group=grpRisk)
maxBars    = input.int(30, "Max Bars in Trade", minval=5, step=5, group=grpRisk, tooltip="Force exit after N bars")

// ──────────────────────────────────────────────────────────────────────────────
// TIME HELPERS
// ──────────────────────────────────────────────────────────────────────────────
etHour = hour(time, "America/New_York")

// Handle session spanning midnight
inSession = sessStart > sessEnd
     ? (etHour >= sessStart or etHour < sessEnd)
     : (etHour >= sessStart and etHour < sessEnd)

sessionOK = not useSession or inSession

// ──────────────────────────────────────────────────────────────────────────────
// INDICATORS
// ──────────────────────────────────────────────────────────────────────────────
rsiVal = ta.rsi(close, rsiLen)
atrVal = ta.atr(atrLen)

// ──────────────────────────────────────────────────────────────────────────────
// ENTRY CONDITIONS
// ──────────────────────────────────────────────────────────────────────────────
longCond  = rsiVal < oversold  and sessionOK and strategy.position_size == 0
shortCond = rsiVal > overbought and sessionOK and strategy.position_size == 0

// ──────────────────────────────────────────────────────────────────────────────
// TRADE TRACKING — bars since entry
// ──────────────────────────────────────────────────────────────────────────────
var int barsInTrade = 0

if strategy.position_size != 0
    barsInTrade += 1
else
    barsInTrade := 0

// ──────────────────────────────────────────────────────────────────────────────
// ENTRIES
// ──────────────────────────────────────────────────────────────────────────────
if longCond
    stopPrice = close - atrMult * atrVal
    strategy.entry("Long", strategy.long)
    strategy.exit("Long SL", "Long", stop=stopPrice)
    barsInTrade := 0

if shortCond
    stopPrice = close + atrMult * atrVal
    strategy.entry("Short", strategy.short)
    strategy.exit("Short SL", "Short", stop=stopPrice)
    barsInTrade := 0

// ──────────────────────────────────────────────────────────────────────────────
// EXIT CONDITIONS
// ──────────────────────────────────────────────────────────────────────────────
// RSI mean reversion exit
longExit  = strategy.position_size > 0 and ta.crossover(rsiVal, exitLevel)
shortExit = strategy.position_size < 0 and ta.crossunder(rsiVal, exitLevel)

// Time-based exit
timeExit = barsInTrade >= maxBars

// Session end exit — close if we leave the allowed session
sessionExit = useSession and not inSession and strategy.position_size != 0

if longExit
    strategy.close("Long", comment="RSI Exit")
if shortExit
    strategy.close("Short", comment="RSI Exit")
if timeExit
    strategy.close_all(comment="Max Bars")
if sessionExit
    strategy.close_all(comment="Session End")

// ──────────────────────────────────────────────────────────────────────────────
// PLOTS
// ──────────────────────────────────────────────────────────────────────────────
// Session background highlight
bgcolor(inSession ? color.new(color.blue, 93) : na, title="Asian Session")

// Entry markers
plotshape(longCond,  title="Long Signal",  location=location.belowbar, style=shape.triangleup,   color=color.green, size=size.small, text="BUY")
plotshape(shortCond, title="Short Signal", location=location.abovebar, style=shape.triangledown, color=color.red,   size=size.small, text="SELL")

// Exit markers
plotshape(longExit or shortExit, title="RSI Exit", location=location.absolute, style=shape.xcross, color=color.orange, size=size.tiny)

// ──────────────────────────────────────────────────────────────────────────────
// RSI PANEL (plotted in separate pane automatically since not overlay)
// We use a plot with display=display.status_line to show RSI value in status
// ──────────────────────────────────────────────────────────────────────────────
// Note: Since overlay=true, RSI is shown in the data window / status line.
// Add the built-in RSI indicator to a separate pane for visual reference.
plot(rsiVal, "RSI(2)", color=color.purple, display=display.status_line + display.data_window)

// ──────────────────────────────────────────────────────────────────────────────
// INFO TABLE
// ──────────────────────────────────────────────────────────────────────────────
var table infoTbl = table.new(position.top_right, 2, 5, bgcolor=color.new(color.gray, 85))
if barstate.islast
    table.cell(infoTbl, 0, 0, "RSI(2)",      text_color=color.white)
    table.cell(infoTbl, 1, 0, str.tostring(rsiVal, "#.#"), text_color=rsiVal < oversold ? color.green : rsiVal > overbought ? color.red : color.yellow)
    table.cell(infoTbl, 0, 1, "ATR",          text_color=color.white)
    table.cell(infoTbl, 1, 1, str.tostring(atrVal, format.mintick), text_color=color.yellow)
    table.cell(infoTbl, 0, 2, "Session",      text_color=color.white)
    table.cell(infoTbl, 1, 2, inSession ? "ACTIVE" : "CLOSED", text_color=inSession ? color.green : color.red)
    table.cell(infoTbl, 0, 3, "Bars in Trade",text_color=color.white)
    table.cell(infoTbl, 1, 3, str.tostring(barsInTrade), text_color=barsInTrade > maxBars * 0.8 ? color.red : color.white)
    table.cell(infoTbl, 0, 4, "Position",     text_color=color.white)
    table.cell(infoTbl, 1, 4, str.tostring(strategy.position_size), text_color=color.white)

// ──────────────────────────────────────────────────────────────────────────────
// ALERT CONDITIONS
// ──────────────────────────────────────────────────────────────────────────────
alertcondition(longCond,  title="RSI(2) Long",  message="MGC RSI(2) Mean Reversion: BUY signal triggered")
alertcondition(shortCond, title="RSI(2) Short", message="MGC RSI(2) Mean Reversion: SELL signal triggered")
alertcondition(timeExit,  title="Max Bars Exit", message="MGC RSI(2): Max bars in trade reached — closing position")
