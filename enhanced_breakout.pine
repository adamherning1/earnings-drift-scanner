//@version=5
strategy("Enhanced Breakout Momentum", 
     overlay=true, 
     pyramiding=0, 
     initial_capital=5500, 
     default_qty_type=strategy.fixed, 
     default_qty_value=1,
     commission_type=strategy.commission.cash_per_contract, 
     commission_value=1.25,
     slippage=1)

// ============================================================================
// INPUTS
// ============================================================================

// --- Breakout ---
i_lookback      = input.int(20, "Breakout Lookback", minval=5, group="Breakout")
i_pullbackBars  = input.int(5, "Pullback Window (bars after breakout)", minval=1, maxval=20, group="Breakout")

// --- Filters ---
i_adxLen        = input.int(14, "ADX Length", minval=5, group="Filters")
i_adxMin        = input.int(20, "ADX Minimum", minval=10, group="Filters")
i_volLen        = input.int(20, "Volume MA Length", minval=5, group="Filters")
i_volMult       = input.float(1.0, "Volume Multiplier", minval=0.5, step=0.1, group="Filters")
i_useMacd       = input.bool(true, "Require MACD Histogram > 0", group="Filters")

// --- Risk ---
i_atrPeriod     = input.int(14, "ATR Period", minval=1, group="Risk")
i_initAtrMult   = input.float(2.0, "Initial Stop ATR Mult", minval=0.5, step=0.1, group="Risk")
i_tightAtrMult  = input.float(1.0, "Tight Stop ATR Mult (after 2R)", minval=0.5, step=0.1, group="Risk")
i_riskPct       = input.float(1.5, "Risk Per Trade (%)", minval=0.1, step=0.1, group="Risk") / 100.0
i_pointValue    = input.float(10.0, "Point Value (MGC=$10)", group="Risk")
i_partialPct    = input.float(50.0, "Partial Exit % at 2R", minval=0, maxval=100, group="Risk")

// ============================================================================
// CALCULATIONS
// ============================================================================

atrVal          = ta.atr(i_atrPeriod)
highestHigh     = ta.highest(high[1], i_lookback)

// ADX
[diPlus, diMinus, adxVal] = ta.dmi(i_adxLen, i_adxLen)

// Volume filter
volMA           = ta.sma(volume, i_volLen)
volOk           = volume > volMA * i_volMult

// MACD filter
[macdLine, sigLine, histLine] = ta.macd(close, 12, 26, 9)
macdOk          = i_useMacd ? histLine > 0 : true

// EMA trend context
ema50           = ta.ema(close, 50)
trendUp         = close > ema50

// ============================================================================
// BREAKOUT + PULLBACK LOGIC
// ============================================================================

// Detect fresh breakout
freshBreakout   = close > highestHigh and close[1] <= ta.highest(high[2], i_lookback)

// Track breakout state
var bool  breakoutActive  = false
var int   barsSinceBO     = 0
var float breakoutLevel   = na

if freshBreakout and adxVal > i_adxMin and volOk and macdOk and trendUp
    breakoutActive := true
    barsSinceBO    := 0
    breakoutLevel  := highestHigh

if breakoutActive
    barsSinceBO += 1
    if barsSinceBO > i_pullbackBars
        breakoutActive := false

// Pullback entry: price pulled back near breakout level
pullbackEntry = breakoutActive and barsSinceBO >= 1 and low <= breakoutLevel * 1.002 and close > breakoutLevel

// Direct breakout entry (if pullback doesn't trigger, still enter on strong breakouts)
directEntry   = freshBreakout and adxVal > i_adxMin and volOk and macdOk and trendUp and adxVal > 25

entrySignal   = (pullbackEntry or directEntry) and strategy.position_size == 0

// ============================================================================
// POSITION SIZING
// ============================================================================

stopDist        = atrVal * i_initAtrMult
riskDollars     = strategy.equity * i_riskPct
riskPerContract = stopDist * i_pointValue
lotSize         = math.max(1, math.floor(riskDollars / riskPerContract))

// ============================================================================
// TRADE MANAGEMENT
// ============================================================================

var float entryPrice    = na
var float currentStop   = na
var float initialRisk   = na
var bool  partialTaken  = false
var bool  tightMode     = false

if entrySignal
    stopPrice   = close - stopDist
    strategy.entry("Long", strategy.long, qty=lotSize, comment="Entry")
    strategy.exit("SL", from_entry="Long", stop=stopPrice, comment="InitSL")
    entryPrice  := close
    currentStop := stopPrice
    initialRisk := stopDist
    partialTaken := false
    tightMode   := false
    breakoutActive := false

if strategy.position_size > 0 and not na(initialRisk)
    profitR = (close - entryPrice) / initialRisk
    
    // Partial exit at 2R
    if profitR >= 2.0 and not partialTaken and i_partialPct > 0
        partialQty   = math.max(1, math.floor(strategy.position_size * i_partialPct / 100.0))
        strategy.close("Long", qty=partialQty, comment="Partial2R")
        partialTaken := true
        tightMode    := true
    
    // Adaptive trailing stop
    mult = tightMode ? i_tightAtrMult : i_initAtrMult
    newStop = close - atrVal * mult
    newStop := math.max(newStop, currentStop)
    
    if newStop > currentStop
        strategy.exit("SL", from_entry="Long", stop=newStop, comment="TrailSL")
        currentStop := newStop

if strategy.position_size == 0
    entryPrice  := na
    currentStop := na
    initialRisk := na

// ============================================================================
// PLOTTING
// ============================================================================

plot(strategy.position_size > 0 ? currentStop : na, "Stop", color=color.red, style=plot.style_linebr, linewidth=2)
plot(highestHigh, "Breakout Level", color=color.blue, linewidth=1)
plot(ema50, "EMA50", color=color.orange)

bgcolor(breakoutActive ? color.new(color.green, 90) : na)

// ============================================================================
// INFO TABLE
// ============================================================================

if barstate.islastconfirmedhistory
    var table infoTbl = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 80), border_width=1)
    table.cell(infoTbl, 0, 0, "Equity", text_color=color.white)
    table.cell(infoTbl, 1, 0, str.tostring(strategy.equity, "#.##"), text_color=color.green)
    table.cell(infoTbl, 0, 1, "Open P&L", text_color=color.white)
    table.cell(infoTbl, 1, 1, str.tostring(strategy.openprofit, "#.##"), text_color=color.yellow)
    table.cell(infoTbl, 0, 2, "Net Profit", text_color=color.white)
    table.cell(infoTbl, 1, 2, str.tostring(strategy.netprofit, "#.##"), text_color=color.green)
    table.cell(infoTbl, 0, 3, "Trades", text_color=color.white)
    table.cell(infoTbl, 1, 3, str.tostring(strategy.closedtrades), text_color=color.white)
    table.cell(infoTbl, 0, 4, "Win Rate", text_color=color.white)
    winRate = strategy.closedtrades > 0 ? strategy.wintrades / strategy.closedtrades * 100 : 0.0
    table.cell(infoTbl, 1, 4, str.tostring(winRate, "#.#") + "%", text_color=color.white)
    table.cell(infoTbl, 0, 5, "ADX", text_color=color.white)
    table.cell(infoTbl, 1, 5, str.tostring(adxVal, "#.#"), text_color=color.white)

// ============================================================================
// ALERTS
// ============================================================================

alertcondition(entrySignal, title="Long Entry", message="Enhanced Breakout: Long Entry Signal")
alertcondition(strategy.position_size > 0 and strategy.position_size[1] > strategy.position_size, title="Partial Exit", message="Enhanced Breakout: Partial Exit at 2R")
