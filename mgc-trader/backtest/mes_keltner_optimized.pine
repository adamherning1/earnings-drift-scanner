// MES 4H Optimized Keltner Breakout
// KC(14, 0.5), Trail 1.5x ATR, TP 2.0R — Long+Short
// Backtest (1yr): $38,819 | 83 trades | 53% WR | PF 4.55 | DD 16.5%
// Style: Trend-following with tight channel, wide TP — lets winners run
//@version=5
strategy("MES Keltner Breakout v1", overlay=true, default_qty_type=strategy.fixed, default_qty_value=1,
         commission_type=strategy.commission.cash_per_contract, commission_value=0.62,
         slippage=1, calc_on_every_tick=false)

// Inputs
kcLen     = input.int(14, "KC Length", minval=5, maxval=50)
kcMult    = input.float(0.5, "KC Multiplier", minval=0.1, maxval=5.0, step=0.05)
trailMult = input.float(1.5, "Trail ATR Multiplier", minval=0.5, maxval=10.0, step=0.25)
tpMult    = input.float(2.0, "TP as R multiple", minval=0.1, maxval=5.0, step=0.1)
goLong    = input.bool(true, "Allow Longs")
goShort   = input.bool(true, "Allow Shorts")

// Keltner Channel
basis = ta.ema(close, kcLen)
atrVal = ta.atr(kcLen)
upper = basis + kcMult * atrVal
lower = basis - kcMult * atrVal

// Entry conditions (bar close breaks channel)
longCond  = close[1] > upper[1]
shortCond = close[1] < lower[1]

// Risk
risk = atrVal * trailMult

// Long
if longCond and strategy.position_size == 0 and goLong
    entryPrice = open
    strategy.entry("Long", strategy.long)
    strategy.exit("Long TP/SL", "Long", stop=entryPrice - risk, limit=entryPrice + risk * tpMult)

// Short
if shortCond and strategy.position_size == 0 and goShort
    entryPrice = open
    strategy.entry("Short", strategy.short)
    strategy.exit("Short TP/SL", "Short", stop=entryPrice + risk, limit=entryPrice - risk * tpMult)

// Plots
p1 = plot(upper, "Upper KC", color=color.green)
p2 = plot(lower, "Lower KC", color=color.red)
plot(basis, "Basis", color=color.blue)
fill(p1, p2, color=color.new(color.blue, 90))

// Info table
var table infoTable = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 80))
if barstate.islast
    table.cell(infoTable, 0, 0, "KC", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, str.tostring(kcLen) + " / " + str.tostring(kcMult), text_color=color.yellow, text_size=size.small)
    table.cell(infoTable, 0, 1, "Trail", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 1, str.tostring(trailMult) + "x ATR", text_color=color.yellow, text_size=size.small)
    table.cell(infoTable, 0, 2, "TP", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 2, str.tostring(tpMult) + "R", text_color=color.yellow, text_size=size.small)
    table.cell(infoTable, 0, 3, "ATR", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 3, str.tostring(math.round(atrVal, 2)), text_color=color.yellow, text_size=size.small)
