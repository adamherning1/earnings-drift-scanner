//@version=5
strategy("Adaptive Trend Rider", 
     overlay=true, 
     pyramiding=1, 
     initial_capital=5500, 
     default_qty_type=strategy.fixed, 
     default_qty_value=1,
     commission_type=strategy.commission.cash_per_contract, 
     commission_value=1.25,
     slippage=1)

// ============================================================================
// INPUTS
// ============================================================================

// --- Supertrend ---
i_stPeriod      = input.int(10, "Supertrend ATR Period", minval=1, group="Supertrend")
i_stMult        = input.float(3.0, "Supertrend Multiplier", minval=0.5, step=0.5, group="Supertrend")

// --- Donchian ---
i_donchLen      = input.int(20, "Donchian Length", minval=5, group="Donchian")

// --- ADX/DI ---
i_adxLen        = input.int(14, "ADX/DI Length", minval=5, group="Filters")
i_adxMin        = input.int(20, "ADX Minimum", minval=10, group="Filters")
i_diMinDiff     = input.float(5.0, "DI+ - DI- Min Diff", minval=0, group="Filters")

// --- Chandelier Exit ---
i_chandPeriod   = input.int(22, "Chandelier Lookback", minval=5, group="Chandelier Exit")
i_chandMult     = input.float(3.0, "Chandelier ATR Mult", minval=1.0, step=0.5, group="Chandelier Exit")

// --- Risk ---
i_atrPeriod     = input.int(14, "ATR Period", minval=1, group="Risk")
i_stopMult      = input.float(2.0, "Entry Stop ATR Mult", minval=0.5, step=0.1, group="Risk")
i_riskPct       = input.float(1.5, "Risk Per Trade (%)", minval=0.1, step=0.1, group="Risk") / 100.0
i_pointValue    = input.float(10.0, "Point Value (MGC=$10)", group="Risk")

// --- Scale In ---
i_scaleIn       = input.bool(true, "Scale In at 1R profit", group="Scale-In")
i_scaleRisk     = input.float(0.75, "Scale-In Risk %", minval=0.1, step=0.1, group="Scale-In") / 100.0

// ============================================================================
// CALCULATIONS
// ============================================================================

atrVal = ta.atr(i_atrPeriod)

// --- Supertrend ---
[stLine, stDir] = ta.supertrend(i_stMult, i_stPeriod)
trendUp = stDir < 0  // Supertrend returns -1 for uptrend

// --- Donchian Channel ---
donchHigh   = ta.highest(high[1], i_donchLen)
donchLow    = ta.lowest(low[1], i_donchLen)
donchMid    = (donchHigh + donchLow) / 2.0

// --- ADX / DI ---
[diPlus, diMinus, adxVal] = ta.dmi(i_adxLen, i_adxLen)
adxOk       = adxVal > i_adxMin
diOk        = diPlus > diMinus + i_diMinDiff

// --- Chandelier Exit ---
chandHighest    = ta.highest(high, i_chandPeriod)
chandAtr        = ta.atr(i_chandPeriod)
chandelierStop  = chandHighest - chandAtr * i_chandMult

// --- EMA for extra confirmation ---
ema200  = ta.ema(close, 200)
ema50   = ta.ema(close, 50)
emaOk   = ema50 > ema200  // Golden cross context

// ============================================================================
// ENTRY LOGIC
// ============================================================================

breakout    = close > donchHigh
entrySignal = breakout and trendUp and adxOk and diOk and strategy.position_size == 0

// ============================================================================
// POSITION SIZING
// ============================================================================

stopDist        = atrVal * i_stopMult
riskDollars     = strategy.equity * i_riskPct
riskPerContract = stopDist * i_pointValue
lotSize         = math.max(1, math.floor(riskDollars / riskPerContract))

// ============================================================================
// TRADE MANAGEMENT
// ============================================================================

var float entryPrice    = na
var float currentStop   = na
var float initialRisk   = na
var bool  scaledIn      = false
var int   posQty        = 0

if entrySignal
    stp = close - stopDist
    // Use chandelier as alternative stop if higher
    stp := math.max(stp, chandelierStop)
    
    strategy.entry("Long", strategy.long, qty=lotSize, comment="Entry")
    strategy.exit("SL", from_entry="Long", stop=stp, comment="InitSL")
    entryPrice  := close
    currentStop := stp
    initialRisk := close - stp
    scaledIn    := false
    posQty      := lotSize

// Scale-in logic
if strategy.position_size > 0 and i_scaleIn and not scaledIn and not na(initialRisk) and not na(entryPrice)
    if close >= entryPrice + initialRisk  // 1R profit
        scaleRiskDollars    = strategy.equity * i_scaleRisk
        scaleRiskPerC       = stopDist * i_pointValue
        scaleLots           = math.max(1, math.floor(scaleRiskDollars / scaleRiskPerC))
        strategy.entry("Long", strategy.long, qty=strategy.position_size + scaleLots, comment="ScaleIn")
        scaledIn := true
        posQty   += scaleLots

// Chandelier trailing stop
if strategy.position_size > 0 and not na(currentStop)
    // Use the higher of: chandelier exit, or ATR trail from current price
    atrTrail    = close - atrVal * i_stopMult
    bestStop    = math.max(chandelierStop, atrTrail)
    bestStop    := math.max(bestStop, currentStop)  // Never lower the stop
    
    // After 1R, ensure at least breakeven
    if not na(entryPrice) and not na(initialRisk)
        if close >= entryPrice + initialRisk
            bestStop := math.max(bestStop, entryPrice + initialRisk * 0.25)
    
    if bestStop > currentStop
        strategy.exit("SL", from_entry="Long", stop=bestStop, comment="ChandTrail")
        currentStop := bestStop

// Exit if supertrend flips bearish
if strategy.position_size > 0 and not trendUp and trendUp[1]
    strategy.close("Long", comment="STFlip")

if strategy.position_size == 0
    entryPrice  := na
    currentStop := na
    initialRisk := na
    scaledIn    := false
    posQty      := 0

// ============================================================================
// PLOTTING
// ============================================================================

plot(stLine, "Supertrend", color=trendUp ? color.green : color.red, linewidth=2)
plot(donchHigh, "Donchian High", color=color.blue, linewidth=1)
plot(donchLow, "Donchian Low", color=color.blue, linewidth=1)
plot(strategy.position_size > 0 ? currentStop : na, "Stop", color=color.red, style=plot.style_linebr, linewidth=2)
plot(chandelierStop, "Chandelier", color=color.new(color.purple, 50), linewidth=1)
plot(ema50, "EMA50", color=color.orange)
plot(ema200, "EMA200", color=color.gray)

bgcolor(trendUp and adxOk and diOk ? color.new(color.green, 95) : na)

// ============================================================================
// INFO TABLE
// ============================================================================

if barstate.islastconfirmedhistory
    var table infoTbl = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 80), border_width=1)
    table.cell(infoTbl, 0, 0, "Strategy", text_color=color.white)
    table.cell(infoTbl, 1, 0, "Adaptive Trend", text_color=color.teal)
    table.cell(infoTbl, 0, 1, "Equity", text_color=color.white)
    table.cell(infoTbl, 1, 1, str.tostring(strategy.equity, "#.##"), text_color=color.green)
    table.cell(infoTbl, 0, 2, "Net Profit", text_color=color.white)
    table.cell(infoTbl, 1, 2, str.tostring(strategy.netprofit, "#.##"), text_color=color.green)
    table.cell(infoTbl, 0, 3, "Trades", text_color=color.white)
    table.cell(infoTbl, 1, 3, str.tostring(strategy.closedtrades), text_color=color.white)
    table.cell(infoTbl, 0, 4, "Win Rate", text_color=color.white)
    wr = strategy.closedtrades > 0 ? strategy.wintrades / strategy.closedtrades * 100 : 0.0
    table.cell(infoTbl, 1, 4, str.tostring(wr, "#.#") + "%", text_color=color.white)
    table.cell(infoTbl, 0, 5, "ADX", text_color=color.white)
    table.cell(infoTbl, 1, 5, str.tostring(adxVal, "#.#"), text_color=color.white)
    table.cell(infoTbl, 0, 6, "DI+/DI-", text_color=color.white)
    table.cell(infoTbl, 1, 6, str.tostring(diPlus, "#.#") + "/" + str.tostring(diMinus, "#.#"), text_color=color.white)
    table.cell(infoTbl, 0, 7, "Supertrend", text_color=color.white)
    table.cell(infoTbl, 1, 7, trendUp ? "BULL" : "BEAR", text_color=trendUp ? color.green : color.red)

// ============================================================================
// ALERTS
// ============================================================================

alertcondition(entrySignal, title="Long Entry", message="Adaptive Trend: Donchian Breakout Long Entry")
alertcondition(not trendUp and trendUp[1], title="Supertrend Flip", message="Adaptive Trend: Supertrend flipped bearish")
alertcondition(strategy.position_size > 0 and i_scaleIn and not scaledIn and close >= entryPrice + initialRisk, title="Scale In", message="Adaptive Trend: Scale-in at 1R profit")
