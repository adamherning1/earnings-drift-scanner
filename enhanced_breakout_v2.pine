//@version=5
strategy("Enhanced Breakout v2", 
     overlay=true, 
     pyramiding=0, 
     initial_capital=5500, 
     default_qty_type=strategy.fixed, 
     default_qty_value=1,
     commission_type=strategy.commission.cash_per_contract, 
     commission_value=1.25,
     slippage=1,
     currency=currency.USD,
     calc_on_every_tick=false)

// ============================================================================
// INPUTS
// ============================================================================
grpEntry = "Entry"
i_lookback      = input.int(20, "Breakout Lookback", minval=5, group=grpEntry)
i_useEmaFilter  = input.bool(true, "Use EMA Trend Filter", group=grpEntry)
i_emaPeriod     = input.int(50, "EMA Period", minval=10, group=grpEntry)

grpRisk = "Risk Management"
i_atrPeriod     = input.int(14, "ATR Period", minval=1, group=grpRisk)
i_initAtrMult   = input.float(1.5, "Initial Stop ATR Mult", minval=0.5, step=0.1, group=grpRisk)
i_tightAtrMult  = input.float(1.0, "Tight Stop ATR Mult (after 2R)", minval=0.5, step=0.1, group=grpRisk)
i_riskPct       = input.float(1.0, "Risk Per Trade (%)", minval=0.1, step=0.1, group=grpRisk) / 100.0
i_pointValue    = input.float(10.0, "Point Value (MGC=$10)", group=grpRisk)
i_partialAt     = input.float(2.0, "Take Partial at R-Multiple", minval=1.0, step=0.5, group=grpRisk)
i_partialPct    = input.float(50.0, "Partial Exit %", minval=0, maxval=100, group=grpRisk)

// ============================================================================
// INDICATORS
// ============================================================================
atrVal      = ta.atr(i_atrPeriod)
highestHigh = ta.highest(high[1], i_lookback)
ema50       = ta.ema(close, i_emaPeriod)

// ============================================================================
// ENTRY — Same as benchmark but with optional EMA filter
// ============================================================================
trendOk     = not i_useEmaFilter or close > ema50
longCond    = close > highestHigh and trendOk and strategy.position_size == 0

// ============================================================================
// POSITION SIZING
// ============================================================================
stopDist        = atrVal * i_initAtrMult
riskDollars     = strategy.equity * i_riskPct
riskPerContract = stopDist * i_pointValue
lotSize         = math.max(1, math.floor(riskDollars / riskPerContract))

// ============================================================================
// TRADE MANAGEMENT
// ============================================================================
var float entryPrice    = na
var float currentStop   = na
var float initialRisk   = na
var bool  partialTaken  = false
var bool  tightMode     = false

// Entry
if longCond
    stopPrice   = close - stopDist
    strategy.entry("Long", strategy.long, qty=lotSize, comment="Entry")
    strategy.exit("SL", from_entry="Long", stop=stopPrice, comment="InitSL")
    entryPrice  := close
    currentStop := stopPrice
    initialRisk := stopDist
    partialTaken := false
    tightMode   := false

// Manage open position
if strategy.position_size > 0 and not na(initialRisk) and initialRisk > 0
    profitR = (close - entryPrice) / initialRisk
    
    // Partial exit at target R-multiple
    if profitR >= i_partialAt and not partialTaken and i_partialPct > 0
        partialQty   = math.max(1, math.floor(strategy.position_size * i_partialPct / 100.0))
        if partialQty > 0 and partialQty < strategy.position_size
            strategy.close("Long", qty=partialQty, comment="Partial")
        partialTaken := true
        tightMode    := true
    
    // Adaptive trailing stop — tightens after partial taken
    mult = tightMode ? i_tightAtrMult : i_initAtrMult
    newStop = close - atrVal * mult
    newStop := math.max(newStop, currentStop)
    
    if newStop > currentStop
        strategy.exit("SL", from_entry="Long", stop=newStop, comment="Trail")
        currentStop := newStop

// Reset on flat
if strategy.position_size == 0
    entryPrice  := na
    currentStop := na
    initialRisk := na
    partialTaken := false
    tightMode   := false

// ============================================================================
// PLOTS
// ============================================================================
plot(strategy.position_size > 0 ? currentStop : na, "Stop", color=color.red, style=plot.style_linebr, linewidth=2)
plot(highestHigh, "Breakout Level", color=color.new(color.blue, 50), linewidth=1)
plot(i_useEmaFilter ? ema50 : na, "EMA", color=color.orange, linewidth=1)

plotshape(longCond, title="Long", location=location.belowbar, style=shape.triangleup, color=color.green, size=size.small, text="BUY")

// ============================================================================
// INFO TABLE
// ============================================================================
var table infoTbl = table.new(position.top_right, 2, 5, bgcolor=color.new(color.gray, 85))
if barstate.islast
    table.cell(infoTbl, 0, 0, "Equity",     text_color=color.white)
    table.cell(infoTbl, 1, 0, str.tostring(strategy.equity, "#.##"), text_color=color.green)
    table.cell(infoTbl, 0, 1, "Net Profit", text_color=color.white)
    table.cell(infoTbl, 1, 1, str.tostring(strategy.netprofit, "#.##"), text_color=color.green)
    table.cell(infoTbl, 0, 2, "Trades",     text_color=color.white)
    table.cell(infoTbl, 1, 2, str.tostring(strategy.closedtrades), text_color=color.white)
    table.cell(infoTbl, 0, 3, "Position",   text_color=color.white)
    table.cell(infoTbl, 1, 3, str.tostring(strategy.position_size), text_color=color.white)
    table.cell(infoTbl, 0, 4, "Stop",       text_color=color.white)
    table.cell(infoTbl, 1, 4, str.tostring(currentStop, format.mintick), text_color=color.red)

// ============================================================================
// ALERTS
// ============================================================================
alertcondition(longCond, title="Long Entry", message="Enhanced Breakout v2: Long Entry Signal")
