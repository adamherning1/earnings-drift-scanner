// EMA Crossover + ATR Trail — Strategy Lab #2 (Long + Short)
// Python backtest: Score 7418 | Net $16,754 | PF 4.20 | DD 13.3% | 66% WR
// Params: Fast 12, Slow 20, Trend 50, ADX>10, 3.0x ATR trail, no TP, no BE

//@version=5
strategy("EMA Crossover + ATR Trail", overlay=true, initial_capital=5500,
         default_qty_type=strategy.fixed, default_qty_value=1,
         commission_type=strategy.commission.cash_per_contract, commission_value=1.25,
         slippage=1, currency=currency.USD, calc_on_every_tick=false)

// ── Inputs ──────────────────────────────────────────────────────────────────
grpEntry   = "Entry"
fastLen    = input.int(12, "Fast EMA", minval=3, group=grpEntry)
slowLen    = input.int(20, "Slow EMA", minval=5, group=grpEntry)
trendLen   = input.int(50, "Trend EMA", minval=10, group=grpEntry)
adxPeriod  = input.int(14, "ADX Period", minval=5, group=grpEntry)
adxMin     = input.int(10, "Min ADX", minval=5, step=5, group=grpEntry)

grpRisk    = "Risk Management"
atrPeriod  = input.int(14, "ATR Period", minval=1, group=grpRisk)
atrMult    = input.float(3.0, "ATR Trailing Stop Mult", minval=0.5, step=0.1, group=grpRisk)
tpR        = input.float(0.0, "Take Profit R-multiple (0=off)", minval=0, step=0.5, group=grpRisk)
beR        = input.float(0.0, "Move to Breakeven at R (0=off)", minval=0, step=0.5, group=grpRisk)

// ── Indicators ──────────────────────────────────────────────────────────────
fastEma    = ta.ema(close, fastLen)
slowEma    = ta.ema(close, slowLen)
trendEma   = ta.ema(close, trendLen)
atr        = ta.atr(atrPeriod)
[diPlus, diMinus, adxVal] = ta.dmi(adxPeriod, adxPeriod)

// ── Entry signals ───────────────────────────────────────────────────────────
crossUp    = ta.crossover(fastEma, slowEma)
crossDown  = ta.crossunder(fastEma, slowEma)
longEntry  = crossUp   and close > trendEma and adxVal >= adxMin
shortEntry = crossDown and close < trendEma and adxVal >= adxMin

// ── State tracking ──────────────────────────────────────────────────────────
var float entryPrice   = na
var float trailStop    = na
var float initialRisk  = na
var float tpPrice      = na
var bool  beDone       = false
var int   tradeDir     = 0   // 1 = long, -1 = short

// ── Long Entry ──────────────────────────────────────────────────────────────
if longEntry and strategy.position_size <= 0
    if strategy.position_size < 0
        strategy.close("Short", comment="Reverse to Long")
    stopDist    = atr * atrMult
    entryPrice := close
    trailStop  := close - stopDist
    initialRisk := stopDist
    tpPrice    := tpR > 0 ? close + stopDist * tpR : na
    beDone     := false
    tradeDir   := 1
    strategy.entry("Long", strategy.long)
    if not na(tpPrice)
        strategy.exit("Exit Long", "Long", stop=close - stopDist, limit=tpPrice,
                      comment_profit="TP @" + str.tostring(tpR) + "R", comment_loss="Stop")
    else
        strategy.exit("Exit Long", "Long", stop=close - stopDist, comment_loss="Stop")

// ── Short Entry ─────────────────────────────────────────────────────────────
if shortEntry and strategy.position_size >= 0
    if strategy.position_size > 0
        strategy.close("Long", comment="Reverse to Short")
    stopDist    = atr * atrMult
    entryPrice := close
    trailStop  := close + stopDist
    initialRisk := stopDist
    tpPrice    := tpR > 0 ? close - stopDist * tpR : na
    beDone     := false
    tradeDir   := -1
    strategy.entry("Short", strategy.short)
    if not na(tpPrice)
        strategy.exit("Exit Short", "Short", stop=close + stopDist, limit=tpPrice,
                      comment_profit="TP @" + str.tostring(tpR) + "R", comment_loss="Stop")
    else
        strategy.exit("Exit Short", "Short", stop=close + stopDist, comment_loss="Stop")

// ── In-trade management ────────────────────────────────────────────────────
if strategy.position_size != 0 and not na(initialRisk) and initialRisk > 0
    if tradeDir == 1  // Long
        profitR = (close - entryPrice) / initialRisk
        if beR > 0 and not beDone and profitR >= beR
            trailStop := math.max(trailStop, entryPrice)
            beDone := true
        newStop = close - atr * atrMult
        trailStop := math.max(trailStop, newStop)
        if not na(tpPrice)
            strategy.exit("Exit Long", "Long", stop=trailStop, limit=tpPrice,
                          comment_profit="TP @" + str.tostring(tpR) + "R", comment_loss="Trail")
        else
            strategy.exit("Exit Long", "Long", stop=trailStop, comment_loss="Trail")

    if tradeDir == -1  // Short
        profitR = (entryPrice - close) / initialRisk
        if beR > 0 and not beDone and profitR >= beR
            trailStop := math.min(trailStop, entryPrice)
            beDone := true
        newStop = close + atr * atrMult
        trailStop := math.min(trailStop, newStop)
        if not na(tpPrice)
            strategy.exit("Exit Short", "Short", stop=trailStop, limit=tpPrice,
                          comment_profit="TP @" + str.tostring(tpR) + "R", comment_loss="Trail")
        else
            strategy.exit("Exit Short", "Short", stop=trailStop, comment_loss="Trail")

// ── Reset on flat ──────────────────────────────────────────────────────────
if strategy.position_size == 0 and not na(entryPrice)
    entryPrice  := na
    trailStop   := na
    initialRisk := na
    tpPrice     := na
    beDone      := false
    tradeDir    := 0

// ── Plots ───────────────────────────────────────────────────────────────────
plot(fastEma, "Fast EMA", color=color.new(color.lime, 20), linewidth=2)
plot(slowEma, "Slow EMA", color=color.new(color.orange, 20), linewidth=2)
plot(trendEma, "Trend EMA", color=color.new(color.blue, 40), linewidth=1)
plot(strategy.position_size != 0 ? trailStop : na, "Trail Stop", color=color.red, style=plot.style_linebr, linewidth=2)

// Entry markers
plotshape(longEntry  and strategy.position_size[1] <= 0, "Long Entry",  shape.triangleup,   location.belowbar, color.green, size=size.small)
plotshape(shortEntry and strategy.position_size[1] >= 0, "Short Entry", shape.triangledown, location.abovebar, color.red,   size=size.small)

// EMA crossover markers
plotshape(crossUp   and close > trendEma, "Cross Up",   shape.diamond, location.abovebar, color.new(color.yellow, 30), size=size.tiny)
plotshape(crossDown and close < trendEma, "Cross Down", shape.diamond, location.belowbar, color.new(color.purple, 30), size=size.tiny)

// ── Info Table ──────────────────────────────────────────────────────────────
var table infoTbl = table.new(position.top_right, 2, 6, bgcolor=color.new(color.gray, 85))
if barstate.islast
    table.cell(infoTbl, 0, 0, "Equity",     text_color=color.white)
    table.cell(infoTbl, 1, 0, str.tostring(strategy.equity, "#.##"), text_color=color.green)
    table.cell(infoTbl, 0, 1, "Open P&L",   text_color=color.white)
    table.cell(infoTbl, 1, 1, str.tostring(strategy.openprofit, "#.##"), text_color=strategy.openprofit >= 0 ? color.green : color.red)
    table.cell(infoTbl, 0, 2, "Net Profit",  text_color=color.white)
    table.cell(infoTbl, 1, 2, str.tostring(strategy.netprofit, "#.##"), text_color=strategy.netprofit >= 0 ? color.green : color.red)
    table.cell(infoTbl, 0, 3, "Trades",     text_color=color.white)
    table.cell(infoTbl, 1, 3, str.tostring(strategy.closedtrades), text_color=color.white)
    table.cell(infoTbl, 0, 4, "Win Rate",   text_color=color.white)
    winRate = strategy.closedtrades > 0 ? strategy.wintrades / strategy.closedtrades * 100 : 0
    table.cell(infoTbl, 1, 4, str.tostring(winRate, "#.#") + "%", text_color=winRate >= 50 ? color.green : color.orange)
    table.cell(infoTbl, 0, 5, "Stop",       text_color=color.white)
    table.cell(infoTbl, 1, 5, not na(trailStop) ? str.tostring(trailStop, format.mintick) : "—", text_color=color.red)

// ── Alerts ──────────────────────────────────────────────────────────────────
alertcondition(longEntry  and strategy.position_size[1] <= 0, title="EMA Cross Long",  message="EMA Crossover: Long Entry")
alertcondition(shortEntry and strategy.position_size[1] >= 0, title="EMA Cross Short", message="EMA Crossover: Short Entry")
