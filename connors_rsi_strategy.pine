// Connors RSI(2) Optimized — Strategy (Backtestable)
// ====================================================
// Buys oversold dips in uptrends, shorts overbought pops in downtrends.
// Optimized params: 349.9% return, PF 2.34, Sharpe 1.77 on MGC backtest.
//
// @version=5
strategy("Connors RSI(2) Optimized", overlay=true,
         initial_capital=5500,
         default_qty_type=strategy.fixed,
         default_qty_value=1,
         commission_type=strategy.commission.cash_per_contract,
         commission_value=1.25,
         slippage=1,
         currency=currency.USD,
         calc_on_every_tick=false)

// ── Inputs ───────────────────────────────────────────
grpEntry = "Entry"
rsiPeriod     = input.int(2, "RSI Period", minval=1, group=grpEntry)
entryLong     = input.float(12, "RSI Entry Long (below)", minval=1, maxval=50, group=grpEntry)
entryShort    = input.float(88, "RSI Entry Short (above)", minval=50, maxval=99, group=grpEntry)
smaPeriod     = input.int(100, "SMA Trend Filter Period", minval=10, group=grpEntry)

grpExit = "Exit"
exitLong      = input.float(70, "RSI Exit Long (above)", minval=30, maxval=95, group=grpExit)
exitShort     = input.float(30, "RSI Exit Short (below)", minval=5, maxval=70, group=grpExit)
maxHoldBars   = input.int(10, "Max Hold Bars", minval=1, group=grpExit)

grpRisk = "Risk Management"
atrPeriod     = input.int(14, "ATR Period", minval=1, group=grpRisk)
atrStopMult   = input.float(0.5, "ATR Stop Multiplier", minval=0.1, step=0.1, group=grpRisk)
useTrailing   = input.bool(true, "Use ATR Trailing Stop", group=grpRisk)

// ── Calculations ─────────────────────────────────────
rsi2   = ta.rsi(close, rsiPeriod)
sma100 = ta.sma(close, smaPeriod)
atr14  = ta.atr(atrPeriod)

// ── Entry Conditions ─────────────────────────────────
longEntry  = rsi2 < entryLong and close > sma100
shortEntry = rsi2 > entryShort and close < sma100

// ── Exit Conditions ──────────────────────────────────
longExit   = rsi2 > exitLong
shortExit  = rsi2 < exitShort

// ── State Tracking ───────────────────────────────────
var float entryPrice  = na
var float stopPrice   = na
var int   barsHeld    = 0

// ── Entry Logic ──────────────────────────────────────
if longEntry and strategy.position_size == 0
    entryPrice := close
    stopPrice  := close - atr14 * atrStopMult
    barsHeld   := 0
    strategy.entry("Long", strategy.long)

if shortEntry and strategy.position_size == 0
    entryPrice := close
    stopPrice  := close + atr14 * atrStopMult
    barsHeld   := 0
    strategy.entry("Short", strategy.short)

// ── In-Trade Management ──────────────────────────────
if strategy.position_size > 0
    barsHeld += 1

    // ATR trailing stop (only trails up)
    if useTrailing and close > entryPrice
        newStop = close - atr14 * atrStopMult
        stopPrice := math.max(stopPrice, newStop)

    // Exit conditions: RSI exit, max hold, or stop hit
    if longExit or barsHeld >= maxHoldBars
        strategy.close("Long", comment=longExit ? "RSI Exit" : "Time Exit")
        entryPrice := na
        stopPrice  := na
        barsHeld   := 0
    else
        strategy.exit("Stop", "Long", stop=stopPrice, comment_loss="ATR Stop")

if strategy.position_size < 0
    barsHeld += 1

    // ATR trailing stop (only trails down for shorts)
    if useTrailing and close < entryPrice
        newStop = close + atr14 * atrStopMult
        stopPrice := math.min(stopPrice, newStop)

    if shortExit or barsHeld >= maxHoldBars
        strategy.close("Short", comment=shortExit ? "RSI Exit" : "Time Exit")
        entryPrice := na
        stopPrice  := na
        barsHeld   := 0
    else
        strategy.exit("Stop", "Short", stop=stopPrice, comment_loss="ATR Stop")

// ── Reset on Flat ────────────────────────────────────
if strategy.position_size == 0 and not na(entryPrice)
    entryPrice := na
    stopPrice  := na
    barsHeld   := 0

// ── Plots ────────────────────────────────────────────
plot(sma100, "SMA 100", color=color.gray, linewidth=2)
plot(strategy.position_size != 0 ? stopPrice : na, "Stop", color=color.red, style=plot.style_linebr, linewidth=2)

plotshape(longEntry and strategy.position_size[1] == 0,  "Long Entry",  shape.triangleup,   location.belowbar, color.green, size=size.small)
plotshape(shortEntry and strategy.position_size[1] == 0, "Short Entry", shape.triangledown, location.abovebar, color.red,   size=size.small)

// ── Info Table ───────────────────────────────────────
var table infoTbl = table.new(position.top_right, 2, 7, bgcolor=color.new(color.gray, 85))
if barstate.islast
    table.cell(infoTbl, 0, 0, "RSI(2)",     text_color=color.white)
    table.cell(infoTbl, 1, 0, str.tostring(rsi2, "#.0"), text_color=rsi2 < entryLong ? color.green : rsi2 > entryShort ? color.red : color.white)
    table.cell(infoTbl, 0, 1, "Trend",      text_color=color.white)
    table.cell(infoTbl, 1, 1, close > sma100 ? "BULL ▲" : "BEAR ▼", text_color=close > sma100 ? color.green : color.red)
    table.cell(infoTbl, 0, 2, "ATR",        text_color=color.white)
    table.cell(infoTbl, 1, 2, str.tostring(atr14, "#.##"), text_color=color.white)
    table.cell(infoTbl, 0, 3, "Equity",     text_color=color.white)
    table.cell(infoTbl, 1, 3, str.tostring(strategy.equity, "#.##"), text_color=color.green)
    table.cell(infoTbl, 0, 4, "Net Profit", text_color=color.white)
    table.cell(infoTbl, 1, 4, str.tostring(strategy.netprofit, "#.##"), text_color=strategy.netprofit >= 0 ? color.green : color.red)
    table.cell(infoTbl, 0, 5, "Trades",     text_color=color.white)
    table.cell(infoTbl, 1, 5, str.tostring(strategy.closedtrades), text_color=color.white)
    table.cell(infoTbl, 0, 6, "Win Rate",   text_color=color.white)
    winRate = strategy.closedtrades > 0 ? strategy.wintrades / strategy.closedtrades * 100 : 0
    table.cell(infoTbl, 1, 6, str.tostring(winRate, "#.#") + "%", text_color=winRate >= 50 ? color.green : color.orange)

// ── Alerts ───────────────────────────────────────────
alertcondition(longEntry and strategy.position_size == 0,  title="Connors Long",  message="🟢 Connors RSI(2) LONG Entry")
alertcondition(shortEntry and strategy.position_size == 0, title="Connors Short", message="🔴 Connors RSI(2) SHORT Entry")
